# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*~

# Editor / IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Node (if we add tooling later)
node_modules/
package-lock.json
.npm/

# Python (if we add tooling later)
__pycache__/
*.pyc
*.pyo
.venv/

# Build outputs
dist/
build/
.next/
.turbo/
.cache/

# Environment
.env
.env.local
.env.*.local

# Sensitive — never commit credentials
**/credentials*
**/secrets*
**/*.pem
**/*.key

# Squarespace export cruft
squarespace-export/
*.xml.bak

# Large media (committed selectively, not by default)
*.psd
*.ai
*.sketch
*.fig.bak

# Test output
coverage/
.nyc_output/

# OS auto-saved screenshots (Desktop, etc.) — not our mockup screenshots
Screenshot [0-9]*.png
Screen Shot *.png
IMG_[0-9]*.png
*-screenshot-temp.png

# Allow these even in the broader ignore:
!.gitkeep
!README.md
